{
    "chat.disableAIFeatures": true,
    "chat.agent.codeBlockProgress": false,
    "chat.agent.enabled": false,
    "chat.agent.thinking.collapsedTools": "off",
    "chat.agent.thinking.generateTitles": false,
    "chat.checkpoints.enabled": false,
    "chat.detectParticipant.enabled": false,
    "chat.extensionTools.enabled": false,
    "chat.extensionUnification.enabled": false,
    "chat.customAgentInSubagent.enabled": false,
    "editor.detectIndentation": true,
    "editor.tabSize": 4,
    "editor.quickSuggestionsDelay": 10000,
    "files.exclude":{
        "**/.git": true,
        "**/.svn": true,
        "**/.hg": true,
        "**/.DS_Store": true,
        "**/Thumbs.db": true,
        "docs": true
    },
    "git.pruneOnFetch": true,
    "git.suggestSmartCommit": false,
    "python.analysis.aiHoverSummaries": false,
    "python-envs.defaultEnvManager": "ms-python.python:conda",
    "python-envs.defaultPackageManager": "ms-python.python:conda",
    "workbench.colorTheme": "Dark Modern",
    "workbench.tree.indent": 16,
    "workbench.browser.openLocalhostLinks": false,
}
